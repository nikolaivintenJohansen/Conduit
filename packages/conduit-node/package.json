{
  "name": "@conduit/sdk",
  "version": "0.1.0",
  "description": "Smart metering SDK for Conduit. authorize() pre-auth, batched fire-and-forget charge(), clean 402 handling.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist coverage"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "msw": "^2.4.0",
    "prettier": "^3.3.0",
    "rimraf": "^5.0.7",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
