# Copy to .env for local development — never commit real secrets

# App
APP_ENV=development
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://uaw:uaw@localhost:5432/uaw

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRY_SECONDS=3600
KEY_HASH_PEPPER=change-me-in-production

# Stripe (task 4)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=http://localhost:3000/wallet?topup=success
STRIPE_CANCEL_URL=http://localhost:3000/wallet?topup=cancel

# LLM providers (server-side only)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# OAuth2 / OIDC (Phase 3)
OIDC_ISSUER=http://localhost:8000
OAUTH_CODE_EXPIRY_SECONDS=120
OAUTH_ACCESS_TOKEN_EXPIRY_SECONDS=3600
OAUTH_REFRESH_TOKEN_EXPIRY_SECONDS=2592000
OAUTH_DEFAULT_SCOPES=wallet:charge profile:read

# Google login (wallet signup/in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8000/wallet/v1/auth/oauth/google/callback

# Gateway defaults
DEFAULT_RPM_LIMIT=60
DEFAULT_TPM_LIMIT=100000
HOLD_EXPIRY_SECONDS=300

# Phase 4 — ingestion engine (Redis fast path + durable stream)
USAGE_STREAM_NAME=uaw:usage:events
USAGE_CONSUMER_GROUP=billing
USAGE_CONSUMER_NAME=worker-1
USAGE_IDEMPOTENCY_TTL_SECONDS=86400
# Run the billing worker inside the app process (dev); prod runs `python -m services.gateway.worker`
WORKER_ENABLED=false
WORKER_POLL_MS=1000
WORKER_MAX_BATCH=50

# Phase 5 hardening — balance-cache revalidation + worker dead-letter queue
BALANCE_CACHE_TTL_SECONDS=3600
BALANCE_CACHE_STALE_SECONDS=60
BALANCE_CACHE_REVALIDATE_INTERVAL_MS=30000
WORKER_MAX_DELIVERY_ATTEMPTS=5
WORKER_CLAIM_IDLE_MS=60000
USAGE_DLQ_STREAM_NAME=uaw:usage:dlq
